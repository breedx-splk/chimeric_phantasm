         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
    <display-name>curly</display-name>

    <servlet>
        <servlet-name>curly</servlet-name>
        <servlet-class>com.splunk.chimeric.curly.CurlyServlet</servlet-class>
    </servlet>

    <servlet-mapping>
